# =============================================================================
# SME AI Dashboard — Environment Variables
# Copy this file to `.env` (local) or set the same keys in your Vercel
# project's "Environment Variables" UI for production.
# =============================================================================

# -------- AI (required) --------
GEMINI_API_KEY=
# Optional override — defaults to "gemini-2.5-flash"
# GEMINI_MODEL=gemini-2.5-flash

# -------- Server (optional) --------
# PORT=3000

# -------- Database (optional — falls back to in-memory stubs) --------
# For local Postgres:  DATABASE_URL=postgresql://user:pass@localhost:5432/sme_dashboard
# For Supabase:        DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#                      (use the Transaction pooler on port 6543 — serverless-safe)
DATABASE_URL=

# -------- Supabase (optional — used by browser-side real-time + anon reads) --------
# Vite exposes any env var starting with VITE_* to the browser bundle.
# Do NOT prefix with NEXT_PUBLIC_ — that's a Next.js convention that Vite ignores.
# Get these from: https://app.supabase.com/project/<ref>/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -------- Per-tenant Vercel deployments (optional) --------
# Personal Hobby / Pro token from https://vercel.com/account/tokens
# Without this, the admin "Deploy" buttons return 503 with a friendly
# "Vercel not configured" error — everything else still works.
VERCEL_API_TOKEN=

# Only set this if you deploy from a Vercel *Team* account, not a
# personal Hobby one. Leave blank for personal accounts.
# VERCEL_TEAM_ID=

# GitHub repo that backs every tenant storefront. Defaults to this
# repo (kn8trix/AI-Cyber-Monkey-SME-DASH) so a single Vite SPA is
# reused per tenant with VITE_TENANT_ID swapped in at build time.
# VERCEL_STOREFRONT_REPO_URL=kn8trix/AI-Cyber-Monkey-SME-DASH

# Branch / build overrides (rarely needed)
# VERCEL_DEFAULT_BRANCH=main
# VERCEL_BUILD_COMMAND=npm run vercel-build
# VERCEL_OUTPUT_DIR=dist

# -------- Admin API (required for /api/admin/*) --------
# Shared secret required to call /api/admin/* (provisioning, deploy,
# suspend, delete). Sent via the `x-admin-key` header.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# -------- S3 + CloudFront for tenant asset uploads (optional) --------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_BASE=sme-assets
# CDN_DOMAIN=cdn.your-domain.com
# CLOUDFRONT_DISTRIBUTION_ID=
