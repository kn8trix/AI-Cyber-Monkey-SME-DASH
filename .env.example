# =========================================
# SME AI Dashboard - Environment Variables
# =========================================
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must NEVER be committed.
#
#   cp .env.example .env
#
# Required:
#   GEMINI_API_KEY  - Google AI Studio API key (https://aistudio.google.com/apikey)
#
# Optional:
#   GEMINI_MODEL    - Model ID override (default: gemini-2.5-flash)
#   PORT            - Local dev server port (default: 3000)
#   DATABASE_URL    - Postgres connection string (optional, falls back to in-memory)
# =========================================

# Required: your Google AI Studio key
GEMINI_API_KEY=

# Optional: override the default Gemini model
# GEMINI_MODEL=gemini-2.5-flash

# Optional: dev server port
# PORT=3000

# Optional: Postgres for multi-tenant stores
# DATABASE_URL=postgresql://user:pass@localhost:5432/sme_dashboard
