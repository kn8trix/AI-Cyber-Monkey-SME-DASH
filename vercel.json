{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    ".vercel-build/api/index.cjs": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/.vercel-build/api/index" },
    { "source": "/store/(.*)", "destination": "/.vercel-build/api/index" },
    { "source": "/admin/(.*)", "destination": "/.vercel-build/api/index" },
    { "source": "/(.*)", "destination": "/.vercel-build/api/index" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
